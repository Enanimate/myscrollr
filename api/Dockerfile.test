# Dockerfile.test — builds the core API with dev.enanimate.dev as the FQDN.
# Used by the test stack (compose.test.yml).  Keep this in sync with
# api/Dockerfile — only the COOLIFY_FQDN build arg differs.
#
# To rebuild the core API on the test Coolify instance, trigger a new build
# of this Dockerfile.

FROM golang:1.21-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git && \
    go install github.com/swaggo/swag/cmd/swag@latest

COPY go.mod ./
COPY . .
RUN swag init --parseDependency
RUN go mod tidy
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main .

######## Start a new stage from scratch #######
FROM alpine:latest

WORKDIR /root/

# Override at build time so this image works only for the test environment.
# The rest of the env vars are passed at container runtime via compose.test.yml.
ARG COOLIFY_FQDN=dev.enanimate.dev
ENV API_URL=https://${COOLIFY_FQDN}
ENV LOGTO_URL=https://${COOLIFY_FQDN}/oidc
ENV LOGTO_JWKS_URL=https://${COOLIFY_FQDN}/oidc/jwks
ENV YAHOO_CALLBACK_URL=https://${COOLIFY_FQDN}/yahoo/callback

RUN apk --no-cache add curl

COPY --from=builder /app/main .
COPY --from=builder /app/docs ./docs

EXPOSE 8080

CMD ["./main"]
